# PostgreSQL
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=bybit_lab
POSTGRES_USER=bybit_lab_user
POSTGRES_PASSWORD=change_me
POSTGRES_CONNECT_TIMEOUT_SEC=5

# App
APP_HOST=127.0.0.1
APP_PORT=8000
DEFAULT_CATEGORY=linear
DEFAULT_SYMBOLS=BTCUSDT,ETHUSDT,SOLUSDT
DEFAULT_INTERVAL=60
MAX_SYMBOLS_PER_REQUEST=50
MAX_SYNC_DAYS=730

# ML/runtime
# Оставьте пустым для автонастройки. На Windows авто-дефолт намеренно меньше числа логических ядер, чтобы joblib/loky не вызывал отсутствующий wmic.
ML_MAX_CPU_COUNT=
LOKY_MAX_CPU_COUNT=
# ML больше не требует ручного обучения по каждому символу: фоновый контур сам
# переобучает отсутствующие/устаревшие модели category+symbol+interval+horizon.
ML_AUTO_TRAIN_ENABLED=true
ML_AUTO_TRAIN_TTL_HOURS=168
ML_AUTO_TRAIN_HORIZON_BARS=24
ML_AUTO_TRAIN_MAX_MODELS_PER_CYCLE=8
ML_AUTO_TRAIN_FAILURE_COOLDOWN_HOURS=1
ML_PROBABILITY_IN_SIGNALS_ENABLED=true

# Bybit public REST. Только публичные endpoints; реальные ордера проект не отправляет.
BYBIT_BASE_URL=https://api.bybit.com
BYBIT_REQUEST_SLEEP_SEC=0.12
BYBIT_TIMEOUT_SEC=30
BYBIT_MAX_RETRIES=4
BYBIT_RETRY_BACKOFF_SEC=0.75
# Общий лимит одновременных HTTP-запросов к Bybit для фоновой параллельной загрузки.
BYBIT_MAX_CONCURRENT_REQUESTS=4

# Управляемый параллелизм тяжелых операций. Держите значения консервативными, чтобы не упереться в rate limits Bybit и PostgreSQL.
MARKET_SYNC_WORKERS=4
SIGNAL_BUILD_WORKERS=2
BACKTEST_AUTO_WORKERS=2

# Symbol universe / liquidity filter
SYMBOL_MODE=hybrid
CORE_SYMBOLS=BTCUSDT,ETHUSDT,SOLUSDT,XRPUSDT,DOGEUSDT,BNBUSDT,ADAUSDT,SUIUSDT,AAVEUSDT,LINKUSDT,AVAXUSDT,LTCUSDT,NEARUSDT,1000PEPEUSDT,HYPEUSDT
EXCLUDE_SYMBOLS=USDCUSDT,USDEUSDT,FDUSDUSDT
DYNAMIC_SYMBOL_LIMIT=40
UNIVERSE_LIMIT=40
MIN_TURNOVER_24H=20000000
MIN_OPEN_INTEREST_VALUE=15000000
MAX_SPREAD_PCT=0.05
MIN_LISTING_AGE_DAYS=45
ALLOW_UNVERIFIED_CORE_SYMBOLS=false

# Free sentiment pipeline
USE_FEAR_GREED=true
USE_GDELT=true
USE_RSS=true
USE_MARKET_SENTIMENT=true
USE_CRYPTOPANIC=false
CRYPTOPANIC_TOKEN=
SENTIMENT_LOOKBACK_DAYS=7
SENTIMENT_HTTP_TIMEOUT_SEC=3
GDELT_HTTP_TIMEOUT_SEC=6
GDELT_CIRCUIT_BREAKER_FAILURES=2
GDELT_FAILURE_COOLDOWN_SEC=300
GDELT_MAX_RECORDS=50
RSS_URLS=https://www.coindesk.com/arc/outboundfeeds/rss/|CoinDesk,https://cointelegraph.com/rss|Cointelegraph

# Ollama-compatible local LLM
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=qwen3:8b
OLLAMA_TIMEOUT_SEC=60

# Risk defaults for recommendation/backtest mode
START_EQUITY_USDT=500
RISK_PER_TRADE=0.005
MAX_BACKTEST_DRAWDOWN=0.03
# Backward compatibility: MAX_DAILY_DRAWDOWN is still read if MAX_BACKTEST_DRAWDOWN is unset.
# MAX_DAILY_DRAWDOWN=0.03
FEE_RATE=0.00055
SLIPPAGE_RATE=0.00020
MAX_POSITION_NOTIONAL_USDT=1000
MAX_LEVERAGE=2
REQUIRE_LIQUIDITY_FOR_SIGNALS=true
MAX_SIGNAL_AGE_HOURS=48

# Background signal refresher
# Полный автоматический MTF-контур рекомендаций: universe -> market/sentiment по TF -> signals -> backtest/LLM.
# Не отправляет ордера; только обновляет витрину ручного оператора.
# SIGNAL_AUTO_INTERVALS — независимые Bybit-таймфреймы; по умолчанию 15m/1h/4h.
SIGNAL_AUTO_REFRESH_ENABLED=true
SIGNAL_AUTO_REFRESH_INTERVAL_SEC=300
SIGNAL_AUTO_REFRESH_STARTUP_DELAY_SEC=20
SIGNAL_AUTO_MAX_SYMBOLS=25
SIGNAL_AUTO_SYNC_DAYS=30
SIGNAL_AUTO_INTERVALS=15,60,240
SIGNAL_AUTO_REFRESH_UNIVERSE=true
SIGNAL_AUTO_SYNC_SENTIMENT=true

# Intraday MTF consensus
# Безопасная иерархия: 15m = entry trigger, 60m = directional bias, 240m = старший regime/veto.
# 60m/240m не считаются самостоятельным trigger на вход; они фильтруют 15m.
MTF_CONSENSUS_ENABLED=true
MTF_ENTRY_INTERVAL=15
MTF_BIAS_INTERVAL=60
MTF_REGIME_INTERVAL=240


# Background backtest runner
# Автоматически поддерживает свежие backtest-доказательства по актуальным symbol+strategy.
# Не отправляет ордера и не меняет рекомендации; тяжелая работа ограничена количеством кандидатов.
BACKTEST_AUTO_ENABLED=true
BACKTEST_AUTO_INTERVAL_SEC=900
BACKTEST_AUTO_STARTUP_DELAY_SEC=45
BACKTEST_AUTO_MAX_CANDIDATES=8
BACKTEST_AUTO_LIMIT=5000
BACKTEST_AUTO_TTL_HOURS=24

# Background LLM evaluator
# Фоновая оценка top-кандидатов. Не торгует и не отправляет ордера; только сохраняет риск-разбор.
LLM_AUTO_EVAL_ENABLED=true
LLM_AUTO_EVAL_INTERVAL_SEC=300
LLM_AUTO_EVAL_STARTUP_DELAY_SEC=15
LLM_AUTO_EVAL_MAX_CANDIDATES=8
LLM_AUTO_EVAL_WORKERS=2
LLM_AUTO_EVAL_TTL_MINUTES=60
